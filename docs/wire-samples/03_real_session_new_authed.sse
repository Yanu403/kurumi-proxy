data: {"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"14eedaaa-5ac8-48a9-95e1-6c7f59df67d4","update":{"sessionUpdate":"config_option_update","configOptions":[{"type":"select","id":"mode","name":"Permission Mode","description":"Controls how the agent requests permission before making changes","category":"mode","currentValue":"bypassPermissions","options":[{"value":"default","name":"Always Ask","description":"Prompts for permission on first use of each tool"},{"value":"acceptEdits","name":"Accept Edits","description":"Automatically accepts file edit permissions for the session"},{"value":"plan","name":"Plan","description":"Agent can analyze but not modify files or execute commands"},{"value":"bypassPermissions","name":"Bypass Permissions","description":"Skips all permission prompts"},{"value":"fullAccess","name":"Full Access","description":"Skips ALL permission checks including dangerous commands for all agents"}]},{"type":"select","id":"model","name":"Model","description":"Select the AI model to use for this session","category":"model","currentValue":"codewise-chat","options":[{"value":"codewise-chat","name":"Codewise-Chat","description":"x0.01 credits"}]},{"type":"select","id":"thought_level","name":"Deep Thinking","description":"Choose reasoning effort level for this session","category":"thought_level","currentValue":"enabled","options":[{"value":"disabled","name":"Off","description":"Standard response without extended thinking"},{"value":"minimal","name":"Minimal","description":"Briefest reasoning"},{"value":"low","name":"Low","description":"Light reasoning"},{"value":"medium","name":"Medium","description":"Balanced reasoning"},{"value":"high","name":"High","description":"Deep reasoning"},{"value":"xhigh","name":"X-High","description":"Very deep reasoning"},{"value":"max","name":"Max","description":"Maximum reasoning effort"},{"value":"enabled","name":"On (default)","description":"Use the model default effort"}]},{"type":"select","id":"sandbox","