# Optional downstream API key. When set, /v1/* requires:
# Authorization: Bearer <value>
KURUMI_PROXY_API_KEY=

# Required for real CodeBuddy chat calls.
CODEBUDDY_API_KEY=

CODEBUDDY_BIN=codebuddy
CODEBUDDY_MODEL=default-model
CODEBUDDY_TIMEOUT_SECONDS=180
KURUMI_PROXY_MAX_OUTPUT_TOKENS=8192

# Local router database. Stores CodeBuddy credential metadata and usage history.
# The actual SQLite file is ignored by git.
KURUMI_PROXY_DB_PATH=runtime/kurumi_proxy.sqlite3

# Multi-key routing. fill-first uses lowest priority first; round-robin rotates keys.
KURUMI_PROXY_ROUTING_STRATEGY=fill-first
KURUMI_PROXY_STICKY_ROUND_ROBIN_LIMIT=3

# RTK-lite token saver. Compresses only large tool/tool_result payloads.
KURUMI_PROXY_RTK_ENABLED=true
KURUMI_PROXY_RTK_MIN_BYTES=2000
KURUMI_PROXY_RTK_MAX_BYTES=200000
KURUMI_PROXY_RTK_HEAD_LINES=120
KURUMI_PROXY_RTK_TAIL_LINES=80

# Multi-provider dispatch. When a request omits the "provider/model" prefix,
# route it to this provider. One of: codebuddy, merlin
KURUMI_PROXY_DEFAULT_PROVIDER=codebuddy

# --- Merlin (getmerlin.in) provider ---
# Firebase project + API key for anonymous auth. Defaults work out of the box.
MERLIN_FIREBASE_API_KEY=AIzaSyAvCgtQ4XbmlQGIynDT-v_M8eLaXrKmtiM
MERLIN_FIREBASE_PROJECT=foyer-work
# Default model when a request uses "merlin/" without a model.
MERLIN_DEFAULT_MODEL=gemini-2.5-flash-lite
MERLIN_BASE_URL=https://www.getmerlin.in
MERLIN_REQUEST_TIMEOUT_SECONDS=180
# Optional: reuse a captured Firebase refresh token (Pro session) instead of
# anonymous sign-up. Format: "<idToken>|<refreshToken>". Unlocks Pro models.
# MERLIN_REFRESH_TOKEN=

